<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data extraction rules. Because allowBackup is
    disabled in the manifest these rules only govern cloud / device-to-device
    transfer, which is also opted out by default. Both <cloud-backup> and
    <device-transfer> explicitly disable transfer of any app data.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>